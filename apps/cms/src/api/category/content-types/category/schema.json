{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Kategoria",
    "description": "Kategorie ebooków"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },  
    "ebooks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ebook.ebook",
      "inversedBy": "categories"
    }
  }
}
