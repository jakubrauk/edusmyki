{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Opinia",
    "description": "Opinie klientów o ebook-ach"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "content": {
      "type": "text",
      "required": true
    },
    "authorName": {
      "type": "string",
      "required": true
    },
    "authorRole": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": true
    },
    "ebook": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ebook.ebook"
    },
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::order.order"
    },
    "featuredOnHomepage": {
      "type": "boolean",
      "default": false
    }
  }
}
