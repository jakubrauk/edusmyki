{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Zamówienie",
    "description": "Zamówienia w sklepie"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "paid", "cancelled", "refunded"],
      "default": "pending",
      "required": true
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "order.order-item"
    },
    "totalAmount": {
      "type": "decimal",
      "required": true
    },
    "guestEmail": {
      "type": "email"
    },
    "guestFirstName": {
      "type": "string"
    },
    "guestLastName": {
      "type": "string"
    },
    "p24TransactionId": {
      "type": "string"
    },
    "p24OrderId": {
      "type": "string"
    },
    "invoiceRequested": {
      "type": "boolean",
      "default": false
    },
    "invoiceData": {
      "type": "component",
      "repeatable": false,
      "component": "order.invoice-data"
    },
    "paidAt": {
      "type": "datetime"
    },
    "ipAddress": {
      "type": "string"
    }
  }
}
